<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YARGA MOTO - Nouvelle Version</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@900&family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <style>
        * { box-sizing: border-box; max-width: 100vw; }
        body { margin: 0; font-family: 'Inter', sans-serif; background: #f9f9f9; color: #333; overflow-x: hidden; }
        header { padding: 15px; border-bottom: 1px solid #eee; background: white; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-family: 'Orbitron'; font-weight: 900; font-size: 1.2em; cursor: pointer; user-select: none; }
        
        #side-menu { position: fixed; top: 0; right: -300px; width: 280px; height: 100%; background: white; box-shadow: -5px 0 15px rgba(0,0,0,0.1); z-index: 10000; transition: 0.3s; padding: 25px; overflow-y: auto; }
        #side-menu.active { right: 0; }
        .menu-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; }
        .menu-overlay.active { display: block; }
        .menu-header { display:flex; justify-content:space-between; align-items:center; margin-bottom: 20px; }
        .menu-title { font-size: 1.2em; font-weight: 800; color: #333; }
        .menu-section { color:#ffcc00; font-weight:800; margin-top:25px; font-size:0.75em; letter-spacing: 1px; margin-bottom: 10px; }
        .menu-item { display: flex; align-items: center; gap: 12px; padding: 15px 0; text-decoration: none; color: #444; font-weight: 600; border-bottom: 1px solid #f9f9f9; transition: 0.2s; cursor: pointer; }
        .menu-item:hover { color: #ffcc00; }
        .contact-box { margin-top:20px; padding:15px; background:#f9f9f9; border-radius:12px; font-size: 0.85em; }

        #search-bar { width: 90%; margin: 15px auto; display: block; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 1em; }
        
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; padding: 10px; width: 100%; }
        
        #admin-panel { display: none; padding: 20px; border-top: 5px solid #ffcc00; background: white; margin-top: 20px; }
        #loading-screen { position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); color:#fff; display:flex; justify-content:center; align-items:center; z-index:9999; }
        
        .card { 
            background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); 
            padding: 10px; text-align: center; border: 1px solid #eee; display: flex; 
            flex-direction: column; cursor: pointer; height: 220px; overflow: hidden;
        }
        
        .card img { width: 100%; height: 120px; object-fit: contain; border-radius: 8px; margin-bottom: 8px; }
        .card h3 { margin: 5px 0; font-size: 0.85em; height: 35px; overflow: hidden; display: flex; align-items: center; justify-content: center; }
        
        .stock-badge { background: #e8f8f0; color: #2ecc71; font-size: 0.6em; font-weight: 800; padding: 2px 6px; border-radius: 4px; display: inline-block; margin-bottom: 5px; }

        #detail-page {
            display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); 
            width:90%; max-width:400px; background:white; padding:20px; border-radius:20px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.3); z-index: 20000;
        }
    </style>
</head>
<body>

    <div id="loading-screen">Chargement...</div>

    <section id="detail-page">
        <button onclick="document.getElementById('detail-page').style.display='none';" style="background:none; border:none; cursor:pointer; font-weight:bold;">FERMER X</button>
        <img id="detail-img" style="width:100%; height:200px; object-fit:contain; border-radius:16px;">
        <h1 id="detail-nom" style="font-size:1.2em; margin:15px 0 5px 0;"></h1>
        <p id="detail-modele" style="color:#666; font-weight:bold; margin:0;"></p>
        <p id="detail-prix" style="font-size:1.5em; color:#ff9900; font-weight:900; margin:10px 0;"></p>
        <p id="detail-desc" style="color:#444; font-size:0.9em; margin-bottom:20px;"></p>
        <a id="btn-acheter" href="#" target="_blank" style="display:block; text-align:center; padding:12px; background:#25D366; color:white; text-decoration:none; border-radius:12px; font-weight:bold;">ACHETER MAINTENANT</a>
    </section>

    <div id="main-container">
        <div class="menu-overlay" id="menu-overlay"></div>
        <nav id="side-menu">
            <div class="menu-header">
                <div class="menu-title">MENU</div>
                <span class="material-symbols-outlined" id="close-menu" style="cursor:pointer;">close</span>
            </div>
            
            <a class="menu-item" onclick="filterData('ALL')"><span class="material-symbols-outlined">home</span> TOUT LE STOCK</a>
            
            <div class="menu-section">MODÈLES</div>
            <a class="menu-item" onclick="filterData('SANYA/SANILI')">SANYA/SANILI</a>
            <a class="menu-item" onclick="filterData('SIRUIS')">SIRUIS</a>
            <a class="menu-item" onclick="filterData('TVS 125')">TVS 125</a>
            <a class="menu-item" onclick="filterData('HAOJUE')">HAOJUE</a>
            
            <div class="menu-section">INFOS & CONTACT</div>
            <div class="contact-box">
                <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
                    <strong>HORAIRES</strong>
                    <span style="background:#2ecc71; color:white; padding:2px 8px; border-radius:4px; font-size:0.7em;">OUVERT</span>
                </div>
                <div>Lun - Sam : 08h00 - 18h00</div>
                <div style="color:#999;">DIMANCHE : FERMÉ</div>
            </div>

            <a href="tel:+22665409190" class="menu-item">📞 +226 65 40 91 90</a>
            <a href="mailto:yargamoto@gmail.com" class="menu-item">✉️ yargamoto@gmail.com</a>
            <div style="font-size:0.8em; color:#999; margin-top:10px;">📍 BOGANDE, Burkina Faso</div>
        </nav>

        <header>
            <div class="logo" id="main-logo">YARGA<span>MOTO</span></div>
            <span class="material-symbols-outlined" id="menu-btn" style="cursor:pointer;">menu</span>
        </header>

        <input type="text" id="search-bar" placeholder="Rechercher une pièce...">

        <main>
            <div id="list" class="grid"></div>
        </main>

        <section id="admin-panel">
            <h2>Zone Administration</h2>
            <input type="text" id="new-nom" placeholder="Nom de la pièce" style="display:block; margin-bottom:10px; width:90%;">
            <input type="number" id="new-prix" placeholder="Prix" style="display:block; margin-bottom:10px; width:90%;">
            <input type="text" id="new-img-url" placeholder="Coller le lien de l'image ici" style="display:block; margin-bottom:10px; width:90%;">
            <button id="btn-publier" style="padding:10px 20px; background:#ffcc00; border:none; cursor:pointer; font-weight:bold; border-radius:5px;">PUBLIER</button>
        </section>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getFirestore, collection, onSnapshot, addDoc } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyBfv_Yx23DItLu1XuohYU2t6DR1qsfXHTg",
            authDomain: "yarga-location.firebaseapp.com",
            projectId: "yarga-location",
            storageBucket: "yarga-location.firebasestorage.app",
            messagingSenderId: "451192909212",
            appId: "1:451192909212:web:3a94d275f0ea70546aac59",
            measurementId: "G-M4SE8DYZ6Q"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);

        const menuBtn = document.getElementById('menu-btn');
        const sideMenu = document.getElementById('side-menu');
        const overlay = document.getElementById('menu-overlay');
        const adminPanel = document.getElementById('admin-panel');
        const listContainer = document.getElementById('list');
        const searchBar = document.getElementById('search-bar');

        let allPieces = [];

        // Fonction d'affichage
        window.renderPieces = (pieces) => {
            listContainer.innerHTML = "";
            pieces.forEach((docSnap) => {
                const p = docSnap.data();
                const card = document.createElement('div');
                card.className = "card";
                card.innerHTML = `
                    <div style="text-align:left;"><span class="stock-badge">● EN STOCK</span></div>
                    <img src="${p.img || 'https://via.placeholder.com/150'}">
                    <h3 style="font-size: 0.85em; margin: 5px 0;">${p.nom.toUpperCase()}</h3>
                `;
                card.onclick = () => {
                    document.getElementById('detail-img').src = p.img || 'https://via.placeholder.com/150';
                    document.getElementById('detail-nom').innerText = p.nom;
                    document.getElementById('detail-modele').innerText = "Modèle : " + (p.modele || "Non spécifié");
                    document.getElementById('detail-prix').innerText = p.prix.toLocaleString() + " CFA";
                    document.getElementById('detail-desc').innerText = p.desc || "Aucune description disponible.";
                    document.getElementById('btn-acheter').href = `https://wa.me/22665409190?text=Bonjour, je souhaite acheter : ${p.nom} (${p.prix} CFA)`;
                    document.getElementById('detail-page').style.display = 'block';
                };
                listContainer.appendChild(card);
            });
        };

        // Filtrage global
        window.filterData = (modele) => {
            if(modele === 'ALL') renderPieces(allPieces);
            else renderPieces(allPieces.filter(d => d.data().modele === modele));
            sideMenu.classList.remove('active'); overlay.classList.remove('active');
        };

        // Recherche en temps réel
        searchBar.oninput = (e) => {
            const val = e.target.value.toLowerCase();
            renderPieces(allPieces.filter(d => d.data().nom.toLowerCase().includes(val)));
        };

        menuBtn.onclick = () => { sideMenu.classList.add('active'); overlay.classList.add('active'); };
        overlay.onclick = () => { sideMenu.classList.remove('active'); overlay.classList.remove('active'); };

        onSnapshot(collection(db, "pieces"), (snapshot) => { allPieces = snapshot.docs; renderPieces(allPieces); });
        
        document.getElementById('btn-publier').onclick = async () => {
            const nom = document.getElementById('new-nom').value;
            const prix = document.getElementById('new-prix').value;
            const url = document.getElementById('new-img-url').value;
            const desc = prompt("Description :");
            const modele = prompt("Modèle (SANYA/SANILI, SIRUIS, TVS 125, HAOJUE) :");
            if(nom && prix && url && modele) {
                await addDoc(collection(db, "pieces"), { nom, prix: parseInt(prix), img: url, modele, desc });
                alert("Ajouté !");
            }
        };
        
        document.getElementById('loading-screen').style.display = 'none';
    </script>
</body>
</html>
