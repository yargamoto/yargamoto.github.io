<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YARGA MOTO - BANTIA COMMERCE/title>
    <link href="https://fonts.googleapis.com/css2?family=Audiowide&family=Rajdhani:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <style>
        * { box-sizing: border-box; max-width: 100vw; }
        body { margin: 0; font-family: 'Rajdhani', sans-serif; background: #f4f4f4; color: #333; overflow-x: hidden; }
        
        #loading-screen { position: fixed; top:0; left:0; width:100%; height:100%; background: white; display:flex; flex-direction:column; justify-content:center; align-items:center; z-index: 999999; }
        .logo-text { font-family: 'Audiowide', sans-serif; font-size: 3em; color: #222; margin-bottom: 20px; letter-spacing: 2px; text-align: center; }
        .logo-text span { display: block; color: #ffcc00; font-size: 0.8em; text-shadow: 0 0 10px rgba(255, 204, 0, 0.5); }
        .loader-container { width: 200px; height: 6px; background: #eee; border-radius: 3px; overflow: hidden; }
        .loader-bar { width: 0%; height: 100%; background: #ffcc00; animation: fill 2s ease-in-out infinite; }
        @keyframes fill { 0% { width: 0%; } 50% { width: 100%; } 100% { width: 0%; } }
        @keyframes fadeIn { from { opacity: 0; transform: translate(-50%, -60%); } to { opacity: 1; transform: translate(-50%, -50%); } }

        /* Bannière modale centrée */
        #welcome-banner { 
            display: none; 
            position: fixed; 
            top: 50%; left: 50%; transform: translate(-50%, -50%);
            background: white; 
            padding: 25px; 
            width: 85%; max-width: 350px;
            border-radius: 20px; 
            box-shadow: 0 20px 50px rgba(0,0,0,0.3); 
            text-align: center;
            z-index: 30000;
        }
        #welcome-banner h4 { margin: 0 0 10px 0; color: #ffcc00; font-family: 'Audiowide', sans-serif; }
        #welcome-banner p { margin: 0 0 15px 0; font-size: 0.95em; color: #555; }
        .close-banner { position: absolute; top: 10px; right: 15px; cursor: pointer; color: #999; font-size: 20px; font-weight: bold; }

        header { padding: 15px; border-bottom: 1px solid #eee; background: white; display: flex; justify-content: space-between; align-items: center; }
        .logo { font-family: 'Audiowide', sans-serif; font-weight: 900; font-size: 1.5em; cursor: pointer; user-select: none; letter-spacing: 1px; }
        .logo span { color: #ffcc00; }
        
        #side-menu { position: fixed; top: 0; right: -300px; width: 280px; height: 100%; background: white; box-shadow: -5px 0 15px rgba(0,0,0,0.1); z-index: 10000; transition: 0.3s; padding: 25px; overflow-y: auto; }
        #side-menu.active { right: 0; }
        .menu-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; }
        .menu-overlay.active { display: block; }
        .menu-header { display:flex; justify-content:space-between; align-items:center; margin-bottom: 20px; }
        .menu-title { font-size: 1.2em; font-weight: 800; color: #333; }
        .menu-section { color:#ffcc00; font-weight:800; margin-top:25px; font-size:0.75em; letter-spacing: 1px; margin-bottom: 10px; }
        .menu-item { display: flex; align-items: center; gap: 12px; padding: 15px 0; text-decoration: none; color: #444; font-weight: 600; border-bottom: 1px solid #f9f9f9; transition: 0.2s; cursor: pointer; }
        .menu-item:hover { color: #ffcc00; }
        
        .contact-box { background:#f9f9f9; padding:15px; border-radius:12px; margin-top:10px; }
        .contact-row { display:flex; align-items:center; gap:10px; font-size:0.9em; margin-bottom:10px; }
        .contact-btn { display: flex; align-items: center; gap: 12px; padding: 12px; margin-top: 8px; text-decoration: none; color: #333; font-weight: 600; border: 1px solid #eee; border-radius: 10px; transition: 0.2s; }
        .contact-btn:hover { background: #fffdf0; border-color: #ffcc00; }

        #search-bar { width: 90%; margin: 15px auto; display: block; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 1em; }
        
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; padding: 15px; transition: opacity 0.3s ease; }
        .grid.searching { opacity: 0; }
        
        .card { background: #fff; border-radius: 16px; padding: 5px; text-align: center; display: flex; flex-direction: column; cursor: pointer; height: 230px; position: relative; border: 1px solid #ececec; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 4px 6px rgba(0,0,0,0.03); }
        .card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); border-color: #ffcc00; }
        .card img { width: 100%; height: 175px; object-fit: cover; border-radius: 12px; }
        .card h3 { margin: auto; font-size: 0.8em; font-weight: 700; color: #222; padding: 5px; }
        .stock-badge { color: #2ecc71; font-size: 0.6em; font-weight: 900; position: absolute; top: 12px; left: 12px; z-index: 5; }

        .assistant-btn { position: fixed; bottom: 20px; right: 20px; background: #ffcc00; color: #333; padding: 12px; border-radius: 50%; box-shadow: 0 4px 10px rgba(0,0,0,0.2); cursor: pointer; z-index: 9998; display: flex; align-items: center; justify-content: center; transition: transform 0.3s; }
        .assistant-btn:hover { transform: scale(1.1); }
        
        #back-to-top { position: fixed; bottom: 80px; right: 20px; background: #333; color: white; padding: 10px; border-radius: 50%; cursor: pointer; display: none; z-index: 9997; box-shadow: 0 4px 6px rgba(0,0,0,0.2); align-items: center; justify-content: center; }
        
        #admin-panel { display: none; padding: 20px; border-top: 5px solid #ffcc00; background: white; margin-top: 20px; }
        #detail-page { display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); width:90%; max-width:400px; background:white; padding:25px; border-radius:20px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); z-index: 20000; }
        .close-btn { position: absolute; top: 15px; right: 15px; font-size: 24px; font-weight: bold; cursor: pointer; color: #333; }
        
        #assistant-page { display:none; padding:20px; background:white; min-height:100vh; position:absolute; top:0; left:0; width:100%; z-index: 25000; }
        
        #footer-message { display:none; text-align:center; padding:30px 20px; background:white; margin:15px; border-radius:16px; border:2px dashed #ffcc00; }
        #no-result { display: none; text-align: center; padding: 20px; color: #e74c3c; font-weight: 900; }
    </style>
</head>
<body>

    <div id="loading-screen">
        <div class="logo-text">YARGA<span>MOTO</span></div>
        <div class="loader-container"><div class="loader-bar"></div></div>
    </div>

    <div id="welcome-banner">
        <span class="close-banner" onclick="fermerBanner()">✕</span>
        <h4>BIENVENUE !</h4>
        <p>Merci de visiter <b>YARGA MOTO</b>. Les meilleures pièces à Bogandé.</p>
    </div>

    <div class="assistant-btn" onclick="ouvrirAssistant()">
        <span class="material-symbols-outlined" style="font-size: 28px;">support_agent</span>
    </div>

    <div id="back-to-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
        <span class="material-symbols-outlined">arrow_upward</span>
    </div>

    <section id="assistant-page">
        <h2 style="color:#ffcc00;">ASSISTANCE CLIENT</h2>
        <p>Vous ne trouvez pas une pièce ? Un problème avec votre commandes ?</p>
        <textarea id="msg-wa" style="width:100%; height:150px; border:1px solid #ddd; border-radius:8px; padding:10px; margin-bottom:15px;" placeholder="Écrivez votre message ici..."></textarea>
        <button onclick="window.open('https://wa.me/22665409190?text=' + document.getElementById('msg-wa').value, '_blank')" style="width:100%; padding:15px; background:#25D366; color:white; border:none; border-radius:10px; font-weight:bold; cursor:pointer;">ENVOYER SUR WHATSAPP</button>
        <button onclick="fermerAssistant()" style="width:100%; padding:15px; background:#f4f4f4; border:none; border-radius:10px; margin-top:10px; cursor:pointer;">RETOUR</button>
    </section>

    <section id="detail-page">
        <span class="close-btn" onclick="document.getElementById('detail-page').style.display='none';">X</span>
        <img id="detail-img" style="width:100%; height:200px; object-fit:contain; border-radius:16px;">
        <h1 id="detail-nom" style="font-size:1.2em; margin:15px 0 5px 0;"></h1>
        <p id="detail-modele" style="color:#666; font-weight:bold; margin:0;"></p>
        <p id="detail-prix" style="font-size:1.5em; color:#ff9900; font-weight:900; margin:10px 0;"></p>
        <p id="detail-desc" style="color:#444; font-size:0.9em; margin-bottom:20px;"></p>
        <div style="display:flex; gap:10px;">
            <a id="btn-wa" href="#" target="_blank" style="flex:1; text-align:center; padding:12px; background:#25D366; color:white; text-decoration:none; border-radius:12px; font-weight:bold;">WHATSAPP</a>
            <a id="btn-call" href="#" style="flex:1; text-align:center; padding:12px; background:#333; color:white; text-decoration:none; border-radius:12px; font-weight:bold;">APPELER</a>
        </div>
    </section>

    <div id="main-container">
        <div class="menu-overlay" id="menu-overlay"></div>
        <nav id="side-menu">
            <div class="menu-header">
                <div class="menu-title">MENU</div>
                <span class="material-symbols-outlined" id="close-menu" style="cursor:pointer;" onclick="document.getElementById('side-menu').classList.remove('active'); document.getElementById('menu-overlay').classList.remove('active');">close</span>
            </div>
            
            <a class="menu-item" onclick="filterData('ALL')"><span class="material-symbols-outlined">home</span> TOUT LE STOCK</a>
            
            <div class="menu-section" id="section-titre">NOTRE BOUTIQUE</div>
            <img src="https://i.ibb.co/dsY6PMKH/1780643787285.png" alt="Notre Boutique" style="width: 100%; height: 200px; object-fit: cover; border-radius: 10px;">
            
            <div class="menu-section">HORAIRE & CONTACT</div>
            <div class="contact-box">
                <div class="contact-row">
                    <span class="material-symbols-outlined" style="color: #ffcc00;">schedule</span>
                    <span>Lun-Sam: <b>08h00 - 18h00</b></span>
                </div>
                <div class="contact-row">
                    <span id="status-icon" class="material-symbols-outlined"></span>
                    <span id="status-text" style="font-weight: 800;"></span>
                </div>
                <div class="contact-row" style="margin-top:10px; color:#777; font-size:0.8em;">
                    <span class="material-symbols-outlined">location_on</span> BOGANDÉ, Burkina Faso
                </div>
            </div>

            <hr style="border: 0; border-top: 1px solid #ddd; margin: 20px 0;">

            <a href="tel:+22665409190" class="contact-btn">
                <span class="material-symbols-outlined" style="color:#25D366;">phone</span> +226 65 40 91 90
            </a>
            <a href="mailto:yargamoto@gmail.com" class="contact-btn">
                <span class="material-symbols-outlined" style="color:#ffcc00;">mail</span> yargamoto@gmail.com
            </a>
        </nav>

        <header>
            <div class="logo" id="main-logo">YARGA<span>MOTO</span></div>
            <span class="material-symbols-outlined" id="menu-btn" style="cursor:pointer;">menu</span>
        </header>

        <input type="text" id="search-bar" placeholder="Rechercher une pièce...">
        <div id="no-result">PAS ENCORE DISPONIBLE</div>

        <main>
            <div id="list" class="grid"></div>
            <div id="footer-message">
                <span class="material-symbols-outlined" style="font-size: 40px; color: #ffcc00;">store</span>
                <p style="font-weight: bold;">Passez nous voir à la boutique pour plus de choix !</p>
            </div>
        </main>

        <section id="admin-panel">
            <h2>Zone Administration</h2>
            <input type="text" id="new-nom" placeholder="Nom de la pièce" style="display:block; margin-bottom:10px; width:90%;">
            <input type="number" id="new-prix" placeholder="Prix" style="display:block; margin-bottom:10px; width:90%;">
            <input type="text" id="new-img-url" placeholder="Coller le lien de l'image ici" style="display:block; margin-bottom:10px; width:90%;">
            <button id="btn-publier" style="padding:10px 20px; background:#ffcc00; border:none; cursor:pointer; font-weight:bold; border-radius:5px;">PUBLIER</button>
        </section>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getFirestore, collection, onSnapshot, addDoc, doc, deleteDoc, updateDoc } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        // Bannière bienvenue
        const fermerBanner = () => { document.getElementById('welcome-banner').style.display = 'none'; };
        window.fermerBanner = fermerBanner;

        if (!localStorage.getItem('dejaVisite')) {
            const banner = document.getElementById('welcome-banner');
            banner.style.display = 'block';
            banner.style.animation = 'fadeIn 0.5s ease-out';
            setTimeout(fermerBanner, 3000);
            localStorage.setItem('dejaVisite', 'true');
        }

        window.ouvrirAssistant = () => { document.getElementById('main-container').style.display = 'none'; document.getElementById('assistant-page').style.display = 'block'; };
        window.fermerAssistant = () => { document.getElementById('main-container').style.display = 'block'; document.getElementById('assistant-page').style.display = 'none'; };

        window.onscroll = () => {
            const btn = document.getElementById('back-to-top');
            if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
                btn.style.display = "flex";
            } else {
                btn.style.display = "none";
            }
        };

        const db = getFirestore(initializeApp({
            apiKey: "AIzaSyBfv_Yx23DItLu1XuohYU2t6DR1qsfXHTg",
            authDomain: "yarga-location.firebaseapp.com",
            projectId: "yarga-location",
            storageBucket: "yarga-location.firebasestorage.app",
            messagingSenderId: "451192909212",
            appId: "1:451192909212:web:3a94d275f0ea70546aac59",
            measurementId: "G-M4SE8DYZ6Q"
        }));

        const adminPanel = document.getElementById('admin-panel');
        const listContainer = document.getElementById('list');
        const searchBar = document.getElementById('search-bar');
        const footerMsg = document.getElementById('footer-message');
        const noResult = document.getElementById('no-result');

        let allPieces = [];

        function updateMenuFilters(pieces) {
            document.querySelectorAll('.dynamic-filter').forEach(el => el.remove());
            const models = [...new Set(pieces.map(d => d.data().modele).filter(m => m))];
            const section = document.getElementById('section-titre');
            models.forEach(m => {
                const a = document.createElement('a');
                a.className = "menu-item dynamic-filter";
                a.innerHTML = `<span class="material-symbols-outlined">motorcycle</span> ${m.toUpperCase()}`;
                a.onclick = () => filterData(m);
                section.parentNode.insertBefore(a, section.nextSibling);
            });
        }

        window.renderPieces = (pieces, isSearch = false) => {
            const isAdmin = adminPanel.style.display === 'block';
            listContainer.innerHTML = "";
            if (isSearch) {
                noResult.style.display = pieces.length === 0 ? 'block' : 'none';
                footerMsg.style.display = 'none';
            } else {
                noResult.style.display = 'none';
                footerMsg.style.display = 'block';
            }
            pieces.forEach((docSnap) => {
                const p = docSnap.data();
                const card = document.createElement('div');
                card.className = "card";
                card.innerHTML = `${isAdmin ? `<div style="position:absolute; top:5px; right:5px; z-index:10; display:flex; gap:5px;"><span class="material-symbols-outlined" style="color:red; cursor:pointer; background:white; border-radius:50%;" onclick="supprimerPiece('${docSnap.id}')">delete</span><span class="material-symbols-outlined" style="color:blue; cursor:pointer; background:white; border-radius:50%;" onclick="modifierPiece('${docSnap.id}')">edit</span></div>` : ''}<span class="stock-badge">● EN STOCK</span><img src="${p.img || 'https://via.placeholder.com/150'}"><h3>${p.nom.toUpperCase()}</h3><div style="font-weight:900; color:#ff9900; margin-top:auto; padding-bottom:5px;">${p.prix.toLocaleString()} CFA</div>`;
                card.onclick = (e) => {
                    if(e.target.innerText === 'delete' || e.target.innerText === 'edit') return;
                    document.getElementById('detail-img').src = p.img || 'https://via.placeholder.com/150';
                    document.getElementById('detail-nom').innerText = p.nom;
                    document.getElementById('detail-modele').innerText = "Modèle : " + (p.modele || "Non spécifié");
                    document.getElementById('detail-prix').innerText = p.prix.toLocaleString() + " CFA";
                    document.getElementById('detail-desc').innerText = p.desc || "";
                    document.getElementById('btn-wa').href = `https://wa.me/22665409190?text=Je veux : ${p.nom}`;
                    document.getElementById('btn-call').href = `tel:+22665409190`;
                    document.getElementById('detail-page').style.display = 'block';
                };
                listContainer.appendChild(card);
            });
        };

        searchBar.oninput = (e) => {
            listContainer.classList.add('searching');
            setTimeout(() => {
                const val = e.target.value.toLowerCase();
                const filtered = allPieces.filter(d => d.data().nom.toLowerCase().includes(val));
                renderPieces(filtered, true);
                listContainer.classList.remove('searching');
            }, 300);
        };

        window.supprimerPiece = async (id) => { if(confirm("Supprimer ?")) await deleteDoc(doc(db, "pieces", id)); };
        window.modifierPiece = async (id) => {
            const p = allPieces.find(d => d.id === id).data();
            const n = prompt("Nouveau nom :", p.nom); const pr = prompt("Nouveau prix :", p.prix); const m = prompt("Nouveau modèle :", p.modele || ""); const d = prompt("Nouvelle description :", p.desc || "");
            if(n && pr) await updateDoc(doc(db, "pieces", id), { nom: n, prix: parseInt(pr), modele: m, desc: d });
        };

        window.filterData = (modele) => {
            if(modele === 'ALL') renderPieces(allPieces);
            else renderPieces(allPieces.filter(d => d.data().modele === modele));
            document.getElementById('side-menu').classList.remove('active');
            document.getElementById('menu-overlay').classList.remove('active');
        };

        document.getElementById('menu-btn').onclick = () => { document.getElementById('side-menu').classList.add('active'); document.getElementById('menu-overlay').classList.add('active'); };
        document.getElementById('menu-overlay').onclick = () => { document.getElementById('side-menu').classList.remove('active'); document.getElementById('menu-overlay').classList.remove('active'); };

        const logo = document.getElementById('main-logo');
        let pressTimer;
        logo.addEventListener('touchstart', () => pressTimer = setTimeout(() => { if(prompt("Code admin :") === "654091") { adminPanel.style.display = 'block'; renderPieces(allPieces); } }, 3000));
        logo.addEventListener('touchend', () => clearTimeout(pressTimer));

        onSnapshot(collection(db, "pieces"), (snapshot) => { 
            allPieces = snapshot.docs; 
            renderPieces(allPieces); 
            updateMenuFilters(allPieces);
            setTimeout(() => { document.getElementById('loading-screen').style.display = 'none'; }, 800);
        });
        
        document.getElementById('btn-publier').onclick = async () => {
            const nom = document.getElementById('new-nom').value; const prix = document.getElementById('new-prix').value; const url = document.getElementById('new-img-url').value; const modele = prompt("Modèle :");
            if(nom && prix && url && modele) { await addDoc(collection(db, "pieces"), { nom, prix: parseInt(prix), img: url, modele }); alert("Ajouté !"); }
        };
    </script>
</body>
</html>
